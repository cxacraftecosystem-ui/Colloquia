// TranscriptAI — standalone transcription product.
//
// This schema shares the SAME Postgres (Supabase) instance as the field-repository app. To coexist
// safely every model is namespaced with `@@map("ta_*")`, AND status/role/type fields use plain
// `String` columns instead of Prisma enums: a Prisma enum creates a Postgres TYPE named after the
// enum, which would collide with the field-repo's existing types (UserRole, AuthProvider, ...). Using
// String keeps the two apps fully independent in one database. Allowed values are documented inline
// and validated in application code.

generator client {
  provider                    = "prisma-client-py"
  interface                   = "asyncio"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  // MASTER_ADMIN | ADMIN | USER
  role         String  @default("USER")
  // LOCAL | GOOGLE
  authProvider String  @default("LOCAL")

  // Per-user app preferences (dark mode, default language, recording quality, auto-upload/transcribe/
  // summary, notification prefs, privacy). JSON so the UI can evolve without migrations.
  settingsJson Json?

  recordings Recording[]
  folders    Folder[]
  tags       Tag[]
  jobs       ProcessingJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ta_users")
}

model Folder {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  color    String?
  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[] @relation("FolderTree")

  recordings Recording[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("ta_folders")
}

model Tag {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String

  recordings RecordingTag[]

  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@map("ta_tags")
}

model Recording {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  aiTitle  String?
  language String?

  // Audio object in S3-compatible storage. objectKey is unique so /complete is idempotent on retry
  // (the key embeds uploader id + a per-upload uuid), exactly like the field-repo media flow.
  objectKey        String  @unique
  bucket           String?
  url              String?
  mimeType         String?
  originalFilename String?
  sizeBytes        Int?
  durationSec      Int?

  // UPLOADING | UPLOADED | PROCESSING | COMPLETED | FAILED
  status           String  @default("UPLOADING")
  // PENDING | QUEUED | PROCESSING | COMPLETED | FAILED | RATE_LIMITED | UNAVAILABLE | EMPTY
  transcriptStatus String  @default("PENDING")
  transcriptError  String?

  isFavorite Boolean @default(false)
  isArchived Boolean @default(false)
  isPinned   Boolean @default(false)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  transcript     Transcript?
  summaries      Summary[]
  actionItems    ActionItem[]
  extractedItems ExtractedItem[]
  chatMessages   ChatMessage[]
  tags           RecordingTag[]
  jobs           ProcessingJob[]

  recordedAt   DateTime  @default(now())
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, isArchived, isFavorite])
  @@map("ta_recordings")
}

model RecordingTag {
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recordingId, tagId])
  @@map("ta_recording_tags")
}

model Transcript {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // PENDING | PROCESSING | COMPLETED | FAILED
  status      String    @default("PENDING")
  rawText     String?
  refinedText String?
  language    String?
  model       String?
  durationMs  Int?

  segments TranscriptSegment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ta_transcripts")
}

model TranscriptSegment {
  id           String     @id @default(cuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  idx          Int
  speaker      String?
  startMs      Int
  endMs        Int
  text         String
  // Set when a user edits the segment inline; the original `text` is preserved as the source of truth.
  editedText   String?

  @@index([transcriptId, idx])
  @@map("ta_transcript_segments")
}

model Summary {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // BRIEF | DETAILED | BULLETS | MINUTES
  type        String
  content     String
  model       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recordingId, type])
  @@map("ta_summaries")
}

model ActionItem {
  id               String    @id @default(cuid())
  recordingId      String
  recording        Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // ACTION | DECISION | TAKEAWAY | DEADLINE
  kind             String    @default("ACTION")
  text             String
  assignee         String?
  dueDate          DateTime?
  done             Boolean   @default(false)
  sourceSegmentIdx Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recordingId, kind])
  @@map("ta_action_items")
}

model ExtractedItem {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // ENTITY | KEYWORD | TOPIC
  kind        String
  value       String
  score       Float?

  createdAt DateTime @default(now())

  @@index([recordingId, kind])
  @@map("ta_extracted_items")
}

model ChatMessage {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // USER | ASSISTANT
  role        String
  content     String

  createdAt DateTime @default(now())

  @@index([recordingId, createdAt])
  @@map("ta_chat_messages")
}

// Durable work queue. One elected worker drains it (see services/media_queue.py + main.py), so heavy
// Whisper/AI calls never run on the request path. Mirrors the field-repo MediaProcessingJob.
model ProcessingJob {
  id          String    @id @default(cuid())
  // TRANSCRIPTION | ANALYSIS
  jobType     String
  // QUEUED | PROCESSING | COMPLETED | FAILED | CANCELLED
  status      String    @default("QUEUED")
  priority    Int       @default(50)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAfter    DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  result      Json?

  recordingId   String
  recording     Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   User?     @relation(fields: [requestedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAfter, priority, createdAt])
  @@map("ta_processing_jobs")
}

// Global, master-admin-configurable settings (single row, id="singleton"): transcription mode +
// optional off-peak window for heavy work. Mirrors the field-repo AppSetting.
model AppSetting {
  id                 String  @id @default("singleton")
  transcriptionMode  String  @default("REFINED")
  defaultLanguage    String?
  batchWindowEnabled Boolean @default(false)
  batchWindowStart   String  @default("02:00")
  batchWindowEnd     String  @default("05:00")
  batchTimezone      String  @default("Asia/Kolkata")
  updatedById        String?

  updatedAt DateTime @updatedAt

  @@map("ta_app_settings")
}

