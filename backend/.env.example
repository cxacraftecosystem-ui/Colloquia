# TranscriptAI backend env. Copy to .env and fill in. Reuses the same infra/credentials as the
# field-repository app (AWS S3, OpenAI, Supabase Postgres, Google OAuth web client).

# Same Supabase Postgres as the field-repo (tables are namespaced ta_* so they don't collide).
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/field_repository
DATABASE_USE_TRANSACTION_POOLER=true
DATABASE_CONNECTION_LIMIT=10

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_MINUTES=10080

# Same S3 bucket. Local dev points at MinIO; production uses AWS S3 (leave AWS_S3_ENDPOINT unset for AWS).
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=field-repository
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_PUBLIC_BASE_URL=http://localhost:9000/field-repository

APP_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Google OAuth (web client id used for ID-token verification; same project as the field-repo).
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

MASTER_ADMIN_EMAIL=ankits1802@gmail.com
MASTER_ADMIN_NAME=Ankit Kumar

# Seed admin (local email/password login).
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=TranscriptAI Admin
ADMIN_PASSWORD=

# OpenAI — Whisper transcription + gpt-4o-mini analysis/chat. Absent => transcription UNAVAILABLE.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_CHAT_MODEL=gpt-4o-mini

# Background processing queue.
MEDIA_QUEUE_WORKER_ENABLED=true
MEDIA_QUEUE_INTERVAL_SECONDS=5
MEDIA_QUEUE_BATCH_SIZE=3
MEDIA_QUEUE_JOB_MAX_ATTEMPTS=3

# Phase 2 — lite mode (compute-light) toggle + optional provider keys.
LITE_MODE=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DEEPGRAM_API_KEY=
FCM_SERVER_KEY=
